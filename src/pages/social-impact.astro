---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Founder Impact | Radynox-Draivra',
  description: 'How we measure success: founder outcomes, business sustainability, and market impact.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Founder Impact"
    title="Measure success through founder outcomes and business sustainability"
    subtitle="Radynox-Draivra focuses on helping founders build sustainable, scalable businesses with healthy operations and sustainable growth."
    callToAction={{ text: 'Learn more', href: '/contact' }}
  />

  <Features2
    title="How we define success"
    columns={3}
    items={[
      {
        title: 'Founder wellbeing',
        description:
          'We measure impact by founder bandwidth gained, burnout reduced, and focus reclaimed for strategy and growth.',
        icon: 'tabler:heart',
      },
      {
        title: 'Business sustainability',
        description:
          'Our work creates durable operations, healthy team structures, and financially sound businesses built to last.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Scalable growth',
        description: 'We succeed when founders can scale from solo execution to organized operations without crisis.',
        icon: 'tabler:rocket',
      },
    ]}
  />
</Layout>
