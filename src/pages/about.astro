---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Radynox-Draivra | Founder Execution Systems',
  description: 'Helping founders build operational systems, scale sustainably, and move from chaos to clarity.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Radynox-Draivra"
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Founder-led operations and execution',
    }}
  >
    <Fragment slot="title">
      We help founders move from chaos to <span class="text-accent dark:text-white">operational clarity</span>.
    </Fragment>

    <Fragment slot="subtitle">
      Radynox-Draivra exists because most founders struggle with the same problems: unclear workflows, scattered knowledge, founder bottlenecks, and the constant pressure of execution. We provide the systems, frameworks, and guidance to make operations scalable and sustainable.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Our Impact"
    stats={[
      { title: 'Founders Supported', amount: '500+' },
      { title: 'Systems Implemented', amount: '200+' },
      { title: 'Revenue Generated (combined)', amount: '$50M+' },
      { title: 'Team Members Hired', amount: '1K+' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Founder challenges we solve"
    subtitle="The operational gaps every growing founder faces."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Founder bottleneck',
        description:
          'Everything flows through the founder. Decisions slow, knowledge gets lost, and scaling becomes impossible without systems.',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Execution pressure',
        description: 'Constant firefighting instead of strategy. No clear workflows, scattered processes, unclear responsibilities.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Scale without systems',
        description:
          'Adding team members breaks things because there are no documented processes. Quality declines as you grow.',
        icon: 'tabler:trending-up',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Systems design',
        description: 'We design operational systems that scale: hiring, financial management, decision-making frameworks, team communication.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Implementation support',
        description: 'We guide you through adoption, train your team, and iterate based on real-world feedback.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Founder community',
        description: 'You\'re not alone. Connect with other founders solving the same problems and learning from shared experience.',
        icon: 'tabler:users',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Founder systems and operations',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="How we work"
    subtitle="A practical process grounded in listening, mapping, and sharing useful next steps."
    items={[
      {
        title: 'Listen to your stage',
        description:
          'We start by understanding where you are, what you are trying to build, and what resources you already have.',
      },
      {
        title: 'Map available paths',
        description: 'We connect you to communities, programs, and practical resources that match your current needs.',
      },
      {
        title: 'Share the next step',
        description:
          'We focus on one clear, practical next step rather than promising a broad roadmap or quick success.',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our values"
    tagline="What guides us"
    columns={3}
    items={[
      {
        title: 'Humble clarity',
        description: 'We speak plainly about what we can and cannot do, and we avoid hype or exaggerated claims.',
        icon: 'tabler:award',
      },
      {
        title: 'Founder-first thinking',
        description:
          'We design our work around the real needs of early-stage people and small teams, not around a narrow definition of “startup.”',
        icon: 'tabler:user',
      },
      {
        title: 'Community-minded',
        description:
          'We prioritize connections and pathways that welcome a broad range of backgrounds, locations, and resources.',
        icon: 'tabler:heart',
      },
    ]}
  />
</Layout>
