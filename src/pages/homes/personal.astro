---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Founder Journey & Growth | Radynox-Draivra',
  description: 'Explore the stages of founder growth, from idea to scale. Resources and guidance for your journey.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'Stages', href: '#about' },
        { text: 'Milestones', href: '#resume' },
        { text: 'Stories', href: '#porfolio' },
        { text: 'Blog', href: '#blog' },
        { text: 'About Us', href: '/about' },
      ]}
      actions={[
        {
          text: 'Start Journey',
          href: '/contact',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Your Founder Journey"
    tagline="Founder Growth & Development"
    actions={[{ variant: 'primary', text: 'Start your growth path', href: getPermalink('/contact#form') }]}
  >
    <Fragment slot="subtitle">
      From first idea to sustainable business. Every founder follows a path of challenges, learnings, and growth. <br /> We
      document the journey, celebrate the milestones, and provide the resources you need at each stage. You're not alone in
      this—join founders building what matters.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:rocket',
        callToAction: {
          target: '_blank',
          text: 'Resources',
          href: '/contact',
        },
      },
      {
        icon: 'tabler:users',
        callToAction: {
          target: '_blank',
          text: 'Community',
          href: '/contact',
        },
      },
      {
        icon: 'tabler:book',
        callToAction: {
          target: '_blank',
          text: 'Guide',
          href: '/blog',
        },
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Founder growth journey',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Your Growth Path</h2>
      <p>
        Every founder's journey is unique. But there are common stages: ideation, validation, launch, growth, and scaling.
      </p>
      <br />
      <p>
        We provide frameworks, tools, and community at each stage. Connect with founders who've walked your path. Learn from
        their wins and mistakes. Move forward with clarity.
      </p>
      <br />
      <p>Get started with the resources, join the community, or dive into our founder guide:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Founder Growth Stages"
    items={[
      {
        title:
          'Stage 1: Ideation & Validation <br /> <span class="font-normal">The Explorer</span> <br /> <span class="text-sm font-normal">Months 1-6</span>',
        description: `Define your core problem and validate market fit. <br /> Build your first version or MVP. <br /> Talk to 20-30 potential customers. <br /> Measure if anyone actually cares about your solution.`,
        icon: 'tabler:bulb',
      },
      {
        title:
          'Stage 2: Product-Market Fit <br /> <span class="font-normal">The Builder</span> <br /> <span class="text-sm font-normal">Months 6-18</span>',
        description: `Launch to early users and gather feedback. <br /> Iterate based on what you learn. <br /> Find your first paying customers. <br /> Build repeatable systems for growth.`,
        icon: 'tabler:hammer',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Scaling Milestones"
    items={[
      {
        title: `Stage 3: Growth & Scaling <br /> <span class="font-normal">The Leader</span> <br /> <span class="text-sm font-normal">Year 2-3</span>`,
        icon: 'tabler:trending-up',
      },
      {
        title: `Stage 4: Sustainable Business <br /> <span class="font-normal">The Strategist</span> <br /> <span class="text-sm font-normal">Year 3+</span>`,
        icon: 'tabler:target',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Founder Competencies"
    subtitle="Key skills and mindsets that help founders move from idea to sustainable business."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Product thinking',
        description: 'Understanding customer problems deeply and building solutions that solve real issues.',
      },
      {
        title: 'Execution mindset',
        description: 'Bias toward action, rapid iteration, and learning from real market feedback.',
      },
      {
        title: 'Financial literacy',
        description: 'Knowing your unit economics, runway, and how to make decisions based on real numbers.',
      },
      {
        title: 'Team building',
        description: 'Attracting talent, building culture, and developing people who execute your vision.',
      },
      {
        title: 'Sales and positioning',
        description: 'Understanding how to communicate value and convert customers into believers.',
      },
      {
        title: 'Resilience',
        description: 'Ability to navigate setbacks, adapt quickly, and keep moving forward through uncertainty.',
      },
      {
        title: 'Strategic thinking',
        description: 'Ability to balance daily execution with long-term vision and market opportunity.',
      },
      {
        title: 'Relationship building',
        description: 'Cultivating networks of mentors, investors, partners, and peers who support growth.',
      },
      {
        title: 'Learning agility',
        description: 'Quick to learn new domains, adapt to feedback, and evolve your approach.',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="porfolio"
    title="Founder Success Stories"
    subtitle="Real journeys from founders who started with an idea and built sustainable businesses. Learn from their paths, challenges, and wins."
    isReversed
    items={[
      {
        title: 'Challenge:',
        description:
          'Started with no team and unclear product-market fit. Spent 6 months validating the core problem with customers before building anything.',
      },
      {
        title: 'Solution:',
        description:
          'Implemented a structured validation process, talked to 100+ potential customers, built an MVP based on core feedback, and launched to early adopters. First paying customers within 4 months.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=928&q=80',
      alt: 'Founder growth story',
    }}
    callToAction={{
      target: '_blank',
      text: 'Read the full story',
      icon: 'tabler:chevron-right',
      href: '/blog',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Story 1: <br /><span class="text-2xl">From Idea to First Customers in 6 Months</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Challenge:',
        description:
          'Growing from 5 to 15 team members without clear processes. Decision-making was slow, knowledge was scattered, and the founder was a bottleneck.',
      },
      {
        title: 'Solution:',
        description: `Implemented clear decision frameworks, documented core processes, created an onboarding system, and established team communication protocols. Decision speed improved 3x, and the founder moved from operational tasks to strategy.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Team building story',
    }}
    callToAction={{
      target: '_blank',
      text: 'Read the full story',
      icon: 'tabler:chevron-right',
      href: '/blog',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Story 2: <br /><span class="text-2xl">Scaling from Solo Founder to Team of 15</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Challenge:',
        description: `Revenue was growing but margins were shrinking. The founder didn't understand the unit economics or which customer segments were most profitable.`,
      },
      {
        title: 'Solution:',
        description: `Built a financial dashboard with key metrics: CAC, LTV, payback period, and cohort analysis. Revealed that 20% of customers generated 80% of revenue. Founder refocused marketing spend, improved margins by 35%, and made better growth decisions.`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1664455340023-214c33a9d0bd?ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Financial growth story',
    }}
    callToAction={{
      target: '_blank',
      text: 'Read the full story',
      icon: 'tabler:chevron-right',
      href: '/blog',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Story 3: <br /><span class="text-2xl">From Revenue Confusion to Unit Economics Clarity</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Founder testimonials"
    subtitle="What founders say about building systems, clarity, and sustainable growth."
    testimonials={[
      {
        testimonial: `The frameworks gave us clarity we never had. We went from chaos to a working operating system in 60 days. Our team knows what we're building and why. The execution guidance was the missing piece we needed.`,
        name: 'Alex Chen',
        job: 'Founder & CEO',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Mark Thompson Image',
        },
      },
      {
        testimonial: `We were stuck at $50K MRR and couldn't figure out why. The financial system and metrics framework showed us exactly where to focus. We're now at $200K MRR with better margins. The clarity changed everything.`,
        name: 'Sarah Williams',
        job: 'Founder & CFO',
        image: {
          src: 'https://images.unsplash.com/photo-1554151228-14d9def656e4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=772&q=80',
          alt: 'Emily Martinez Image',
        },
      },
      {
        testimonial: `Building without systems is exhausting. Once we had processes, the team moved faster and I actually had time to think strategy again. The difference between 80-hour weeks and sustainable growth.`,
        name: 'Marcus Johnson',
        job: 'CTO & Co-founder',
        image: {
          src: 'https://images.unsplash.com/photo-1554727242-741c14fa561c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Laura Simmons Image',
        },
      },
      {
        testimonial: `The founder community access was invaluable. Talking to other founders who'd solved the same problems made us feel less alone. We learned from their failures and wins. That support system accelerated our growth by 6 months.`,
        name: 'Priya Sharma',
        job: 'Founder',
        image: {
          src: 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Alex Foster Image',
        },
      },
      {
        testimonial: `I was spinning my wheels trying to do everything. The hiring framework showed us exactly how to bring the right people onto the team. We went from chaos hires to intentional team building. Game changer.`,
        name: 'David Park',
        job: 'Founder & VP People',
        image: {
          src: 'https://images.unsplash.com/photo-1548142813-c348350df52b?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=778&q=80',
          alt: 'Jessica Collins Image',
        },
      },
      {
        testimonial: `The execution pressure was crushing. Having someone help us build real systems meant we could actually breathe and think. Founders talking about sustainable growth isn't hype—it's possible, and the path is clearer than I thought.`,
        name: 'Lisa Rodriguez',
        job: 'Founder',
        image: {
          src: 'https://images.unsplash.com/photo-1566492031773-4f4e44671857?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Michael Carter Image',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready for your next growth stage?"
    subtitle="Join founders building with clarity and execution. Get frameworks, community, and guidance designed for real growth."
    actions={[
      {
        variant: 'primary',
        text: 'Start your journey',
        href: '/contact',
      },
    ]}
  />

  <!-- BlogLatestPost Widget **************** -->

  <BlogLatestPosts
    id="blog"
    title="Founder insights and guides"
    information={`Explore articles, frameworks, and case studies on building systems, scaling teams, financial clarity, and sustainable founder growth. Learn from founders who've walked the path.`}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>
</Layout>
