---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';

const appStoreImg = '~/assets/images/app-store.png';
const appStoreDownloadLink = '/contact';
const googlePlayImg = '~/assets/images/google-play.png';
const googlePlayDownloadLink = '/contact';

const metadata = {
  title: 'Founder Support Platform | Radynox-Draivra',
  description: 'Access founder-focused resources, tools, and guidance to navigate growth challenges and build sustainable systems.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      position="left"
      links={[
        { text: 'Features', href: '#features' },
        { text: 'About', href: '/about' },
        { text: 'Contact', href: '/contact' },
      ]}
      actions={[{ text: 'Download', href: '#download' }]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <Hero2
    tagline="Founder Support Platform"
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Founder platform interface',
    }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">Your support system</span> for every stage of founder growth.
    </Fragment>

    <Fragment slot="subtitle">
      Access tools, templates, frameworks, and guidance when you need it most. Whether you're building operations, scaling your team, or navigating growth—we've got practical resources ready.
    </Fragment>

    <div slot="actions" class="flex max-w-sm gap-4">
      <Button variant="link" href="/contact">
        <Image src={appStoreImg} alt="Get Started" width={200} format="webp" />
      </Button>
      <Button variant="link" href="/contact">
        <Image src={googlePlayImg} alt="Learn More" width={200} format="webp" />
      </Button>
    </div>
  </Hero2>

  <Features3
    id="features"
    title="How to Get Started"
    subtitle="Four simple steps to access founder resources, frameworks, and ongoing support."
    tagline="Quick start guide"
    columns={2}
    items={[
      {
        title: 'Create your founder account',
        description: 'Sign up in seconds and access your personalized dashboard with resources tailored to your stage.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Explore framework library',
        description: 'Browse operational systems, hiring frameworks, financial dashboards, and execution guides.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Download what you need',
        description: 'Get templates, checklists, decision frameworks, and playbooks designed for your specific challenge.',
        icon: 'tabler:download',
      },
      {
        title: 'Connect with support',
        description: 'Schedule 1:1s, join group office hours, or access async guidance to implement systems.',
        icon: 'tabler:phone',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=2069&q=80',
      alt: 'Founder platform dashboard',
    }}
  />

  <Content
    isReversed
    items={[
      {
        title: 'Operations frameworks',
        description: 'Battle-tested systems for hiring, financial management, sales processes, and team alignment built from founder experience.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Decision templates',
        description: 'Playbooks for the founder decisions that keep you up at night: when to hire, how to raise, pivoting your business, and more.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Execution guides',
        description: 'Step-by-step instructions for building systems that work in your actual business, not in theory.',
        icon: 'tabler:book',
      },
      {
        title: 'Real-time access',
        description: 'Get the resources you need right now, not months later. All materials are immediately available for your team.',
        icon: 'tabler:cloud-download',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=1674&q=80',
      alt: 'Founder resources and tools',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Core resources</h3>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'Founder community',
        description: 'Connect with other founders, share challenges, and learn from collective experience.',
        icon: 'tabler:users',
      },
      {
        title: '1:1 guidance',
        description: 'Get personalized advice on implementing systems in your specific business context.',
        icon: 'tabler:phone',
      },
      {
        title: 'Regular updates',
        description: 'New frameworks, guides, and resources added based on founder feedback and market trends.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Success stories',
        description: 'Learn how other founders implemented these systems and the results they achieved.',
        icon: 'tabler:award',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Founder community and support',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Support and community</h3>
    </Fragment>
  </Content>

  <Stats
    title="Founder Impact"
    stats={[
      { amount: '500+', icon: 'tabler:users' },
      { amount: '50M+', icon: 'tabler:currency-dollar' },
      { amount: '95%', icon: 'tabler:award' },
    ]}
  />

  <Testimonials
    title="What founders say"
    testimonials={[
      {
        testimonial:
          'The frameworks saved us months of figuring things out. We went from chaos to a working operating system in 60 days. Our team finally knows what we\'re doing.',
        name: 'Alex Foster',
        job: 'Founder & CEO',
        image: {
          src: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Alex Foster',
        },
      },
      {
        testimonial:
          'The 1:1 guidance when implementing the hiring system was invaluable. We went from reactive hiring to strategic hiring. Game changer.',
        name: 'Marcus Williams',
        job: 'Co-founder',
        image: {
          src: 'https://images.unsplash.com/flagged/photo-1570612861542-284f4c12e75f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Marcus Williams',
        },
      },
      {
        testimonial:
          'Having access to decision templates for the tough founder moments made all the difference. The playbooks work because they\'re designed by people who get startups.',
        name: 'Elena Rodriguez',
        job: 'Founder',
        image: {
          src: 'https://images.unsplash.com/photo-1512361436605-a484bdb34b5f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Elena Rodriguez',
        },
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'Read more founder stories',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <FAQs
    title="Founder support questions"
    items={[
      {
        title: 'What kind of founders use this platform?',
        description:
          'Early-stage founders, scaling founders, technical founders who need operational help, and experienced founders building their next company.',
      },
      {
        title: 'Are the frameworks customizable for my business model?',
        description: 'Yes. The frameworks are starting points. The 1:1 guidance helps you adapt them to your specific context and market.',
      },
      {
        title: 'How much time do I need to invest?',
        description: 'Implementation varies. Some frameworks take a few hours, others a few weeks. The key is starting and iterating, not perfection.',
      },
      {
        title: 'Is this for technical founders only?',
        description: 'No. The platform serves all founder types—technical, non-technical, first-time founders, serial founders. All need systems.',
      },
      {
        title: 'When will I see results?',
        description: 'Clarity comes within days. Real operational change takes 30-60 days. Business impact compounds over 90+ days.',
      },
    ]}
  />

  <CallToAction
    id="download"
    title="Get started with founder resources"
    subtitle="Join 500+ founders building operational systems that actually work. Get your first framework today."
  >
    <div slot="actions" class="flex max-w-sm gap-4">
      <Button variant="link" href={appStoreDownloadLink}>
        <Image src={appStoreImg} alt="App Store" width={200} format="webp" />
      </Button>
      <Button variant="link" href={googlePlayDownloadLink}>
        <Image src={googlePlayImg} alt="Google Play" width={200} format="webp" />
      </Button>
    </div>
  </CallToAction>
</Layout>
'
