---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';

const appStoreImg = '~/assets/images/app-store.png';
const appStoreDownloadLink = '/contact';
const googlePlayImg = '~/assets/images/google-play.png';
const googlePlayDownloadLink = '/contact';

const metadata = {
  title: 'Mobile App Demo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      position="left"
      links={[
        { text: 'Features', href: '#features' },
        { text: 'About', href: '/about' },
        { text: 'Contact', href: '/contact' },
      ]}
      actions={[{ text: 'Download', href: '#download' }]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <Hero2
    tagline="Mobile App Demo"
    image={{
      src: 'https://images.unsplash.com/photo-1535303311164-664fc9ec6532?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Radynox-Draivra App preview',
    }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">Radynox-Draivra App</span>: fast, practical website delivery.
    </Fragment>

    <Fragment slot="subtitle">
      Discover a mobile-first experience for exploring templates, previewing designs, and taking the next step with less
      friction.
    </Fragment>

    <div slot="actions" class="flex max-w-sm gap-4">
      <Button variant="link" href={appStoreDownloadLink}>
        <Image src={appStoreImg} alt="App Store" width={200} format="webp" />
      </Button>
      <Button variant="link" href={googlePlayDownloadLink}>
        <Image src={googlePlayImg} alt="Google Play" width={200} format="webp" />
      </Button>
    </div>
  </Hero2>

  <Features3
    id="features"
    title="How it works"
    subtitle="A simple path to browse templates, preview results, and move toward implementation."
    tagline="Step-by-step guide"
    columns={2}
    items={[
      {
        title: 'Download the app',
        description: 'Open the app and start exploring professionally designed templates in seconds.',
        icon: 'tabler:download',
      },
      {
        title: 'Create your account',
        description: 'Register quickly so you can save favorite templates and access your work across devices.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Browse templates',
        description: 'Choose from mobile-friendly layouts and designs that match your current goals.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Preview and customize',
        description: 'Preview layouts, make lightweight edits, and prepare for your next implementation step.',
        icon: 'tabler:edit',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1521517407911-565264e7d82d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2069&q=80',
      alt: 'Mobile app interface',
    }}
  />

  <Content
    isReversed
    items={[
      {
        title: 'Intuitive interface',
        description: 'A clean layout that makes it easy to browse templates and preview design options.',
        icon: 'tabler:wand',
      },
      {
        title: 'Easy customization',
        description: 'Adjust colors, text, and layout choices without losing the practical focus of your project.',
        icon: 'tabler:settings',
      },
      {
        title: 'Ready-to-use resources',
        description: 'Work faster with prebuilt sections, images, and components designed to launch quickly.',
        icon: 'tabler:template',
      },
      {
        title: 'Live previews',
        description: 'See how the final result will look before moving into implementation.',
        icon: 'tabler:carousel-horizontal',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1576153192621-7a3be10b356e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1674&q=80',
      alt: 'Mobile interface design',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Main features</h3>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'Offline access',
        description: 'Save templates locally so work can continue even without internet access.',
        icon: 'tabler:wifi-off',
      },
      {
        title: 'Secure export',
        description: 'Export approved templates and assets in a way that supports handoff and implementation.',
        icon: 'tabler:file-download',
      },
      {
        title: 'Frequent updates',
        description: 'Access new templates and improvements as the app evolves with practical feedback.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Wishlist support',
        description: 'Save templates you want to revisit later and compare before making a final decision.',
        icon: 'tabler:heart',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1453738773917-9c3eff1db985?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Feature illustration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Additional benefits</h3>
    </Fragment>
  </Content>

  <Stats
    title="App statistics"
    stats={[
      { amount: '20K', icon: 'tabler:download' },
      { amount: '18.5K', icon: 'tabler:users' },
      { amount: '4.7', icon: 'tabler:user-star' },
    ]}
  />

  <Testimonials
    title="What our users say"
    testimonials={[
      {
        testimonial:
          'The app made it simple to find website templates and compare options quickly. The preview flow helped us decide with confidence.',
        name: 'Cary Kennedy',
        job: 'Film director',
        image: {
          src: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Cary Kennedy Image',
        },
      },
      {
        testimonial:
          'Previewing templates and making small edits was intuitive and fast. It helped our team move from idea to implementation without extra overhead.',
        name: 'Josh Wilkinson',
        job: 'Product Manager',
        image: {
          src: 'https://images.unsplash.com/flagged/photo-1570612861542-284f4c12e75f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Josh Wilkinson Image',
        },
      },
      {
        testimonial:
          'Downloading the right template and previewing it in a mobile view made the process much easier than our old setup.',
        name: 'Sidney Hansen',
        job: 'Decorator',
        image: {
          src: 'https://images.unsplash.com/photo-1512361436605-a484bdb34b5f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
          alt: 'Sidney Hansen Image',
        },
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'Read more testimonials',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <FAQs
    title="Still have questions?"
    items={[
      {
        title: 'What does this app do?',
        description:
          'It helps you browse, preview, and select website templates in a mobile-friendly workflow with practical next steps.',
      },
      {
        title: 'How does it help me?',
        description: 'It speeds up template discovery and keeps the focus on launch-ready choices, not busywork.',
      },
      {
        title: 'Is it available on mobile?',
        description: 'Yes, the app is designed to work on a wide range of devices so you can keep moving on the go.',
      },
      {
        title: 'What makes it different?',
        description:
          'It prioritizes practical delivery, clear previews, and reliable next steps rather than flashy promises.',
      },
      {
        title: 'Is there a cost?',
        description: 'The app is free to explore; paid templates or services may vary based on your project needs.',
      },
    ]}
  />

  <CallToAction
    id="download"
    title="Download the app now"
    subtitle="Start with templates that keep your work grounded and your next step clear."
  >
    <div slot="actions" class="flex max-w-sm gap-4">
      <Button variant="link" href={appStoreDownloadLink}>
        <Image src={appStoreImg} alt="App Store" width={200} format="webp" />
      </Button>
      <Button variant="link" href={googlePlayDownloadLink}>
        <Image src={googlePlayImg} alt="Google Play" width={200} format="webp" />
      </Button>
    </div>
  </CallToAction>
</Layout>
'
