---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'Startup Landing Page',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Startup Web Demo"
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Talk to us',
        href: '/contact',
        icon: 'tabler:download',
      },
      { text: 'Learn more', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Build Your <span class="hidden sm:inline">Startup</span> <span
        class="text-accent dark:text-white">Without Building Alone</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Radynox-Draivra</span> helps early-stage founders reduce execution pressure through practical support, operational systems, and long-term partnership.
    </Fragment>

    <Fragment slot="image">
      <div class="bg-gradient-to-br from-blue-100 to-blue-50 dark:from-slate-800 dark:to-slate-900 rounded-lg p-8 flex flex-col items-center justify-center min-h-96">
        <div class="text-center space-y-4">
          <div class="text-5xl font-bold text-blue-600 dark:text-blue-400">→</div>
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white">From Idea to Execution</h3>
          <p class="text-gray-600 dark:text-gray-300 max-w-sm">
            Direct, practical building support — step by step. Not mentorship. Real execution guidance.
          </p>
          <ul class="space-y-2 text-left max-w-sm mx-auto">
            <li class="flex items-start">
              <span class="text-green-600 dark:text-green-400 mr-3 font-bold">✓</span>
              <span class="text-gray-700 dark:text-gray-300">Execution-focused founder support</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-600 dark:text-green-400 mr-3 font-bold">✓</span>
              <span class="text-gray-700 dark:text-gray-300">Operations clarity and systems</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-600 dark:text-green-400 mr-3 font-bold">✓</span>
              <span class="text-gray-700 dark:text-gray-300">Sustainable growth execution</span>
            </li>
          </ul>
        </div>
      </div>
    </Fragment>
  </Hero>

  <!-- Features2 Widget ************** -->

  <Features2
    title="About us"
    subtitle="We help early-stage founders build operational systems and reduce execution pressure. We design practical workflows, coach you through implementation, and provide ongoing support so you can move with clarity and confidence."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Founder impact at Radynox-Draivra"
    subtitle="Real outcomes from helping early-stage founders build sustainable operations and escape founder burnout."
    stats={[
      { title: 'Founders Supported', amount: '500+' },
      { title: 'Revenue Generated', amount: '$50M+' },
      { title: 'Team Members Hired', amount: '1K+' },
      { title: 'Success Rate', amount: '95%' },
    ]}
  />

  <!-- Brands Widget ****************** -->

  <Brands
    title="Partnerships & Integrations"
    subtitle="We work with founders using these tools and platforms to build sustainable operations at scale."
    icons={[]}
    images={[
      {
        src: 'https://cdn.pixabay.com/photo/2015/05/26/09/37/paypal-784404_1280.png',
        alt: 'Paypal',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2021/12/06/13/48/visa-6850402_1280.png',
        alt: 'Visa',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2013/10/01/10/29/ebay-189064_1280.png',
        alt: 'Ebay',
      },

      {
        src: 'https://cdn.pixabay.com/photo/2015/04/13/17/45/icon-720944_1280.png',
        alt: 'Youtube',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2013/02/12/09/07/microsoft-80658_1280.png',
        alt: 'Microsoft',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2015/04/23/17/41/node-js-736399_1280.png',
        alt: 'Node JS',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2015/10/31/12/54/google-1015751_1280.png',
        alt: 'Google',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2021/12/06/13/45/meta-6850393_1280.png',
        alt: 'Meta',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2013/01/29/22/53/yahoo-76684_1280.png',
        alt: 'Yahoo',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our founder execution mission"
    subtitle="At Radynox-Draivra, I help early-stage founders reduce execution pressure by giving them practical support, systems, and direction they were never offered. From day zero to first customers, I sit with founders and help them build what they couldn't build alone."
    items={[
      {
        title: 'Systems that stick',
        description:
          'Design operational systems for hiring, financial management, and team communication that scale with your growth.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Founder breathing room',
        description:
          'Help you move from founder-dependent chaos to organized operations so you can focus on strategy and vision.',
        icon: 'tabler:heart',
      },
      {
        title: 'Early-stage expertise',
        description:
          'Support the stage most ignore: when you\'re building before traction, before visibility, before attention. This is where it matters most.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Who I help specifically"
    subtitle="I work with founders who are building before traction. Before visibility. Before anyone is paying attention. The stage most support systems ignore."
    columns={3}
    items={[
      {
        title: 'Modern and Professional Design',
        description:
          'Have a contemporary design that reflects current design trends and gives a professional impression.',
        icon: 'tabler:artboard',
      },
      {
        title: 'Responsive and Mobile-Friendly',
        description: 'Adapt seamlessly to different screen sizes and devices to ensure a consistent experience.',
        icon: 'tabler:picture-in-picture',
      },
      {
        title: 'Customizability',
        description:
          'Built for flexibility, allowing founders to adjust messaging, visuals, and structure to match their brand goals.',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: 'Fast Loading Times',
        description: 'Optimized for speed to ensure a smooth user experience and favorable search engine rankings.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Search Engine Optimization (SEO)',
        description:
          'Incorporate search-first content structure and messaging so your website is easier to discover by customers and partners.',
        icon: 'tabler:arrows-right-left',
      },
      {
        title: 'Compatibility',
        description:
          'The design and structure work seamlessly across modern platforms and devices, supporting future growth and updates.',
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    items={[
      {
        title: 'What can Radynox-Draivra help my startup build?',
        description:
          'We help founders build operational systems, financial clarity, hiring frameworks, and decision-making processes. From day zero, we help you create the infrastructure that scales.',
      },
      {
        title: 'Why work with Radynox-Draivra?',
        description:
          'We combine founder-minded strategy with practical execution, so you can move from chaos to clarity without losing momentum. You stay focused on your vision while we build the systems that make scale possible.',
      },
      {
        title: 'Can I review the systems we build together?',
        description:
          'Yes. We provide regular checkpoints, documentation, and team feedback so you understand and approve every system before implementation. You stay in control.',
      },
      {
        title: 'Do I need to be technical to work with you?',
        description:
          'No. We work with founders at every stage. We translate execution strategy into actionable systems your team can own and operate. You don\'t need technical background—just commitment to building systems.',
      },
      {
        title: 'Will the systems evolve as my company grows?',
        description:
          'Yes. We build systems designed to scale. As your company grows from solo founder to team to scaled operations, the systems adapt and become more sophisticated.',
      },
      {
        title: 'How do we work together?',
        description:
          'Our process is founder-first: we listen to your challenges, design practical systems, train your team, and iterate based on real execution. Clear communication and your success are everything.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Let us know how we can help"
    subtitle="We’re here to help and answer any question you might have."
    columns={4}
    items={[
      {
        title: 'Phone',
        icon: 'tabler:phone',
        callToAction: {
          target: '_blank',
          text: 'Call us',
          href: '/',
          variant: 'link',
        },
      },
      {
        title: 'Email',
        icon: 'tabler:mail',
        callToAction: {
          target: '_blank',
          text: 'Write to us',
          href: '/',
          variant: 'link',
        },
      },
      {
        title: 'Chat with sales',
        icon: 'tabler:message-circle',
        callToAction: {
          target: '_blank',
          text: 'Start chatting',
          href: '/',
          variant: 'link',
        },
      },
      {
        title: 'Chat with support',
        icon: 'tabler:message-circle',
        callToAction: {
          target: '_blank',
          text: 'Start chatting',
          href: '/',
          variant: 'link',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Talk to us',
        href: '/contact',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">Be a part of our vision</Fragment>

    <Fragment slot="subtitle">
      Discover a dynamic work environment, unparalleled growth opportunities, and the chance to make a meaningful
      impact.
    </Fragment>
  </CallToAction>
</Layout>
