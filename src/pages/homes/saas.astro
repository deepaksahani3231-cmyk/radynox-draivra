---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';

import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Execution Systems for Founders | Radynox-Draivra',
  description: 'Build operational clarity, systems, and execution frameworks for sustainable founder-led growth.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Explore Our Work',
          href: '/about',
        },
        {
          variant: 'primary',
          text: 'Start Your Journey',
          href: '/contact',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Founder Execution Systems"
    actions={[
      { variant: 'primary', target: '_blank', text: 'Talk to us', href: '/contact' },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Founder building systems',
    }}
  >
    <Fragment slot="title">
      Build operational <span class="text-accent dark:text-white">systems that scale</span><br /> with Radynox-Draivra
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Most founders struggle with execution clarity. We help you establish operational systems, clear workflows, and sustainable processes that reduce pressure and enable real growth.</span>
      We focus on practical operations—not theory.
    </Fragment>

    <Features
      id="features"
      title="Why Execution Systems Matter"
      subtitle="Founders often confuse activity with progress. We build the systems that create clarity, efficiency, and sustainable growth."
      columns={2}
      items={[
        {
          title: 'Operations Clarity',
          description:
            'Define roles, workflows, and decision-making processes so everyone moves aligned toward the same goal.',
          icon: 'tabler:layers-union',
        },
        {
          title: 'Scalable Processes',
          description: `Build repeatable systems today that grow with your business tomorrow. Stop reinventing the wheel every quarter.`,
          icon: 'tabler:artboard',
        },
        {
          title: 'Team Alignment',
          description:
            'Create clarity around strategy, ownership, and accountability so your team operates like a cohesive unit.',
          icon: 'tabler:writing',
        },
        {
          title: 'Founder Breathing Room',
          description: `When systems are in place, you spend less time managing chaos and more time on strategic decisions and growth.`,
          icon: 'tabler:podium',
        },
        {
          title: 'Execution Speed',
          description: `Clear systems mean faster decisions, fewer meetings, and real progress toward your business milestones.`,
          icon: 'tabler:rocket',
        },
        {
          title: 'Sustainable Growth',
          description: `Build growth that doesn't require you to work 80-hour weeks. Real founders deserve real lives.`,
          icon: 'tabler:eyeglass',
        },
      ]}
    />

    <!-- Content Widget **************** -->

    <Content
      title="Early-Stage Founder Systems"
      subtitle="Most early-stage founders are stuck in founder-mode: wearing every hat, making every decision, grinding without clear systems."
      isReversed
      items={[
        {
          title: 'The Problem:',
          description:
            'You\'re managing everything yourself. Marketing, operations, customer success, hiring—all on your shoulders. This is unsustainable.',
        },
        {
          title: 'Our Approach:',
          description: `We help you define clear roles and workflows. <br /> Build repeatable processes for your most important activities. <br /> Create decision-making frameworks so you\'re not consulted for every small choice. <br /> Establish metrics that actually matter to your growth. <br /> Move from chaos to controlled execution.`,
        },
      ]}
      image={{
        src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1671&q=80',
        alt: 'Founder building systems',
      }}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
          From Chaos to Clarity <br /><span class="text-2xl">Building Your First Operating System</span>
        </h3>
      </Fragment>

      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </Content>

    <!-- Content Widget **************** -->

    <Content
      isAfterContent={true}
      items={[
        {
          title: 'The Challenge:',
          description: `Growth companies face a unique problem: your old systems don't scale. What worked for 5 people breaks at 15. What worked for 15 breaks at 50.`,
        },
        {
          title: 'Our Solution:',
          description: `We audit your current operations and identify bottlenecks. <br /> Build scalable workflows that your team can execute without constant oversight. <br /> Create accountability structures that maintain quality as you grow. <br /> Establish feedback loops so you catch problems early. <br /> Move from firefighting to strategic leadership.`,
        },
      ]}
      image={{
        src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1658&q=80',
        alt: 'Growing team',
      }}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
          Scale Without Breaking <br /><span class="text-2xl">Operations for Growing Teams</span>
        </h3>
      </Fragment>

      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </Content>

    <!-- Content Widget **************** -->

    <Content
      isReversed
      isAfterContent={true}
      items={[
        {
          title: 'Your Situation:',
          description: `Revenue is growing, but you\'re spending most days on operational tasks instead of strategy. Margins are being squeezed because you\'re not tracking what you should be.`,
        },
        {
          title: 'What We Do:',
          description: `We define financial metrics that actually guide decision-making. <br /> Build reporting systems so you always know your unit economics. <br /> Create operational dashboards for real-time visibility. <br /> Establish forecasting processes that inform strategy. <br /> Turn data into actionable insights.`,
        },
      ]}
      image={{
        src: 'https://images.unsplash.com/photo-1553531088-d1b88b645abd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
        alt: 'Financial systems',
      }}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
          Metrics That Matter <br /><span class="text-2xl">Financial & Operational Clarity</span>
        </h3>
      </Fragment>

      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </Content>

    <!-- Content Widget **************** -->

    <Content
      items={[
        {
          title: 'The Reality:',
          description: `Hiring usually reveals how little documented process actually exists. New team members slow things down because there\'s no clear way to do anything.`,
        },
        {
          title: 'Our Framework:',
          description: `We document your critical paths and knowledge. <br /> Create onboarding systems so new hires contribute faster. <br /> Build communication protocols so your team operates aligned. <br /> Establish feedback and iteration cycles for continuous improvement. <br /> Grow your team without losing your culture.`,
        },
      ]}
      image={{
        src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
        alt: 'Team collaboration',
      }}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
          Hire With Confidence <br /><span class="text-2xl">Building Your Team Operating System</span>
        </h3>
      </Fragment>

      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </Content>

    <!-- Pricing Widget ******************* -->

    <Pricing
      title="Our Engagement Models"
      subtitle="Choose the approach that fits your business stage and execution needs."
      prices={[
        {
          title: 'Strategy Session',
          price: 'Custom',
          period: '3-5 hours',
          items: [
            {
              description: 'Founder & operations audit',
            },
            {
              description: 'Current system gaps analysis',
            },
            {
              description: 'Execution framework recommendations',
            },
            {
              description: 'Strategic roadmap for next 90 days',
            },
          ],
          callToAction: {
            target: '_blank',
            text: 'Schedule Now',
            href: '/contact',
          },
        },
        {
          title: 'Systems Build (Recommended)',
          price: 'Custom',
          period: 'Monthly',
          items: [
            {
              description: 'Deep operational diagnosis',
            },
            {
              description: 'Custom execution frameworks',
            },
            {
              description: 'Process documentation & training',
            },
            {
              description: 'Monthly implementation reviews',
            },
            {
              description: 'Founder 1:1 guidance',
            },
          ],
          callToAction: {
            target: '_blank',
            text: 'Start Building',
            href: '/contact',
          },
          featured: true,
        },
        {
          title: 'Ongoing Operations',
          price: 'Custom',
          period: 'Quarterly',
          items: [
            {
              description: 'Continuous system improvement',
            },
            {
              description: 'Team coaching & development',
            },
            {
              description: 'Quarterly strategy reviews',
            },
            {
              description: 'Real-time support & guidance',
            },
          ],
          callToAction: {
            target: '_blank',
            text: 'Learn More',
            href: '/contact',
          },
        },
      ]}
    />

    <!-- FAQs Widget ******************* -->

    <FAQs
      title="Common Questions About Building Execution Systems"
      subtitle="Clear answers for founders thinking about operational transformation."
      columns={1}
      items={[
        {
          title: 'Why do I need systems? Can\'t I just manage chaos?',
          description: `You can manage chaos, but not at scale. What works at 3 people doesn't work at 5, 10, or 20. Systems are how founders move from "doing everything" to "leading everything."`,
          icon: 'tabler:chevrons-right',
        },
        {
          title: 'How long does it take to see results?',
          description: `Some clarity comes immediately—just defining your critical processes helps. Real operational transformation typically takes 90-180 days of focused work. Growth and scaling results follow after that.`,
          icon: 'tabler:chevrons-right',
        },
        {
          title: 'Will this slow us down in the short term?',
          description: `Maybe by a few days during implementation. But within weeks, you move faster because decisions become clearer and people know what to do without asking. The velocity gain compounds.`,
          icon: 'tabler:chevrons-right',
        },
        {
          title: 'Do you work with bootstrapped startups or only funded companies?',
          description: `We work with founders at every stage. If you're generating revenue and trying to scale, we can help. We offer session-based engagements if you want to start lean.`,
          icon: 'tabler:chevrons-right',
        },
      ]}
    >
      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </FAQs>

    <!-- Steps2 Widget ****************** -->

    <Steps2
      title="How We Work: Your Path to Execution Clarity"
      subtitle="A straightforward process to move from chaos to systems to sustainable growth."
      callToAction={{
        text: 'Get started',
        href: '/contact',
      }}
      items={[
        {
          title: 'Stage 1: Founder & Operations Audit',
          description: `We listen. Deep dives into your current operations, biggest bottlenecks, team structure, and founder pain points. Understanding where you are is the foundation.`,
          icon: 'tabler:mail',
        },
        {
          title: 'Stage 2: System Design & Roadmap',
          description: `We design custom frameworks for your critical processes. Sales funnels, hiring systems, financial dashboards, decision-making protocols. You approve before we build.`,
          icon: 'tabler:headset',
        },
        {
          title: 'Stage 3: Implementation & Training',
          description: `We help your team adopt new systems. Documentation, training, early iteration cycles. We're here to coach, not hand off.`,
          icon: 'tabler:mail',
        },
        {
          title: 'Stage 4: Iterate & Scale',
          description: `Once systems are live, we review what works, refine what doesn't, and prepare for the next phase of growth. Continuous improvement beats perfection.`,
          icon: 'tabler:mail',
        },
      ]}
    />

    <!-- BlogLatestPost Widget **************** -->

    <BlogLatestPosts
      id="blog"
      title="Founder Insights & Execution Guides"
      information={`Explore our collection of articles, guides, and case studies on building operational systems, founder execution frameworks, and scaling your business sustainably.`}
    >
      <Fragment slot="bg">
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
    </BlogLatestPosts>
  </Hero2>
</Layout>
