---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing for Founders | Radynox-Draivra',
  description: 'Flexible founder engagement plans for strategy, execution support, and operational systems that scale with your business.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Pricing"
    title="Founder execution coaching and operations support"
    subtitle="Flexible engagement plans that match your founder stage and growth goals."
  />

  <section id="what-an-engagement-looks-like" class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-10">
      <h2 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">What an Engagement Looks Like</h2>
      <div class="mt-6 space-y-5 text-lg leading-8 text-gray-600 dark:text-slate-300">
        <p>This is a high-touch, founder-to-founder working relationship - not a course, not a template, not a monthly check-in call.</p>
        <p>Engagements are structured around your stage and what you actually need. Most founders start with a focused 4-week sprint, then continue on a monthly basis as the work evolves.</p>
        <p><strong>Engagements typically start at ₹9900/month</strong> (or ~$180/month for international founders). Scope, duration, and structure are agreed transparently before anything begins - no surprises, no upsells.</p>
        <p>If that range doesn't fit where you are right now, say so. We'll either find a way to make it work or I'll tell you honestly if it's not the right time.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Widget ******************* -->

  <Prices
    title="How we work with founders"
    subtitle="Three ways to reduce execution pressure and build sustainable operations."
    prices={[
      {
        title: 'Strategic Clarity Session',
        subtitle: 'You\'re drowning in decisions. Let\'s get clear.',
        price: 2500,
        period: 'single session',
        items: [
          {
            description: 'Deep dive into what\'s actually breaking in your operations',
          },
          {
            description: 'Where your team is losing time and focus',
          },
          {
            description: 'A specific, implementable path forward',
          },
          {
            description: 'Know exactly what to build next',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Get clarity',
          href: '/contact',
        },
      },
      {
        title: 'Systems Build Partnership',
        subtitle: 'We build the foundation together, you get breathing room.',
        price: 5000,
        period: 'per month',
        items: [
          {
            description: 'We design operational systems you actually use',
          },
          {
            description: 'Your team learns how to execute them in real time',
          },
          {
            description: 'Weekly calls to troubleshoot and refine',
          },
          {
            description: '60-90 days to foundational operational change',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Start building',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: 'most founders start here',
      },
      {
        title: 'Ongoing Operations Partnership',
        subtitle: 'You scale with confidence. We\'re the advisor who gets it.',
        price: 10000,
        period: 'per month',
        items: [
          {
            description: 'Someone in your corner who understands founder chaos',
          },
          {
            description: 'Guidance on the decisions that keep you up at night',
          },
          {
            description: 'Systems that evolve with your business',
          },
          {
            description: 'Real partnership, not a transaction',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Talk to us',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What makes this different"
    subtitle="We're not selling services. We're giving you back the founder you were before execution pressure took over."
    columns={2}
    items={[
      {
        title: 'We start with your reality',
        description: 'Not generic frameworks. We audit what\'s actually breaking in your operations.',
        icon: 'tabler:target',
      },
      {
        title: 'You keep what works',
        description: 'We build on your existing strengths, not tear down and rebuild.',
        icon: 'tabler:plant',
      },
      {
        title: 'Your team learns, not depends',
        description: 'We teach your team to execute and improve systems themselves.',
        icon: 'tabler:school',
      },
      {
        title: 'Real timeline, real results',
        description: 'You see founder bandwidth return in 30-60 days, not years.',
        icon: 'tabler:clock',
      },
      {
        title: 'Founded by someone like you',
        description: 'Deepak has been in your shoes. He knows founder pressure firsthand.',
        icon: 'tabler:users',
      },
      {
        title: 'This is a partnership',
        description: 'We succeed when your founder stress goes down, not when you hit a contract renewal.',
        icon: 'tabler:circles-relation',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="The engagement process"
    tagline="From discovery to scaling"
    isReversed={true}
    items={[
      {
        title: 'Founder assessment',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Challenge identification',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Systems design',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Implementation roadmap',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Team training',
        icon: 'tabler:users',
      },
      {
        title: 'Iterate and optimize',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Scale operations',
        icon: 'tabler:trending-up',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Founder execution process',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Common questions about our founder engagement models."
    columns={1}
    items={[
      {
        title: 'What\'s included in each engagement model?',
        description: 'Strategy Sessions include audit and recommendations. Systems Build includes design, documentation, training, and weekly calls. Ongoing Operations includes dedicated advisor, optimization, financial planning, and team coaching.',
      },
      {
        title: 'Can I start with a Strategy Session?',
        description: 'Yes, we recommend starting with a session to assess your situation and determine the right approach. You can then move to Systems Build or Ongoing Operations.',
      },
      {
        title: 'Is the pricing fixed or can it be customized?',
        description: 'Our standard pricing applies to most engagements. For unique situations or multi-month commitments, we can discuss customized pricing.',
      },
      {
        title: 'What if I need to pause or change my engagement?',
        description: 'We work with founders on flexible terms. Let us know your situation and we\'ll find a solution that works.',
      },
      {
        title: 'Do you offer discounts for annual commitments?',
        description: 'Yes, we offer 10% discounts for annual commitments on Systems Build and Ongoing Operations engagements.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to scale your operations?"
    subtitle="Schedule a Strategy Session to assess your founder execution challenges."
    actions={[
      {
        variant: 'primary',
        text: 'Schedule consultation',
        href: '/contact',
      },
    ]}
  />
</Layout>
