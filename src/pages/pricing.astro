---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing for Founders | Radynox-Draivra',
  description: 'Founder execution coaching plans: from strategy sessions to ongoing operations support.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Pricing"
    title="Founder execution coaching and operations support"
    subtitle="Flexible engagement plans that match your founder stage and growth goals."
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Engagement models"
    subtitle="Choose the level of founder execution support that fits your stage."
    prices={[
      {
        title: 'Strategy Session',
        subtitle: 'For founders evaluating systems',
        price: 2500,
        period: 'per session',
        items: [
          {
            description: 'Founder challenge assessment',
          },
          {
            description: 'Operations audit (1-2 areas)',
          },
          {
            description: 'Strategic recommendations',
          },
          {
            description: 'Next-step roadmap',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Schedule session',
          href: '/contact',
        },
      },
      {
        title: 'Systems Build',
        subtitle: 'For founders ready to implement',
        price: 5000,
        period: 'per month',
        items: [
          {
            description: 'Operational systems design',
          },
          {
            description: 'Process documentation',
          },
          {
            description: 'Team training and rollout',
          },
          {
            description: 'Weekly implementation calls',
          },
          {
            description: 'Iteration and refinement',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Get started',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: 'most popular',
      },
      {
        title: 'Ongoing Operations',
        subtitle: 'For founders at scale',
        price: 10000,
        period: 'per month',
        items: [
          {
            description: 'Dedicated operations advisor',
          },
          {
            description: 'Ongoing systems optimization',
          },
          {
            description: 'Strategic financial planning',
          },
          {
            description: 'Bi-weekly strategy calls',
          },
          {
            description: 'Team development and coaching',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Schedule consultation',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Why choose Radynox-Draivra"
    subtitle="Founder-focused engagement models that drive real operational change."
    columns={2}
    items={[
      {
        title: 'Custom engagement',
        description: 'Plans tailored to your founder stage, from strategy to scaling operations.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Transparent pricing',
        description: 'Clear costs with no hidden fees. You know exactly what you\'re investing.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Execution focus',
        description: 'We measure success by your operational improvements and founder bandwidth gained.',
        icon: 'tabler:target',
      },
      {
        title: 'Scalable approach',
        description: 'Start with a session, scale to ongoing partnership as your operations evolve.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Proven methodologies',
        description: 'Systems and frameworks that have helped 500+ founders build sustainable operations.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Founder accountability',
        description: 'Regular check-ins, metrics tracking, and progress reviews to ensure real outcomes.',
        icon: 'tabler:clipboard-list',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="The engagement process"
    tagline="From discovery to scaling"
    isReversed={true}
    items={[
      {
        title: 'Founder assessment',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Challenge identification',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Systems design',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Implementation roadmap',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Team training',
        icon: 'tabler:users',
      },
      {
        title: 'Iterate and optimize',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Scale operations',
        icon: 'tabler:trending-up',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Founder execution process',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Common questions about our founder engagement models."
    columns={1}
    items={[
      {
        title: 'What\'s included in each engagement model?',
        description: 'Strategy Sessions include audit and recommendations. Systems Build includes design, documentation, training, and weekly calls. Ongoing Operations includes dedicated advisor, optimization, financial planning, and team coaching.',
      },
      {
        title: 'Can I start with a Strategy Session?',
        description: 'Yes, we recommend starting with a session to assess your situation and determine the right approach. You can then move to Systems Build or Ongoing Operations.',
      },
      {
        title: 'Is the pricing fixed or can it be customized?',
        description: 'Our standard pricing applies to most engagements. For unique situations or multi-month commitments, we can discuss customized pricing.',
      },
      {
        title: 'What if I need to pause or change my engagement?',
        description: 'We work with founders on flexible terms. Let us know your situation and we\'ll find a solution that works.',
      },
      {
        title: 'Do you offer discounts for annual commitments?',
        description: 'Yes, we offer 10% discounts for annual commitments on Systems Build and Ongoing Operations engagements.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to scale your operations?"
    subtitle="Schedule a Strategy Session to assess your founder execution challenges."
    actions={[
      {
        variant: 'primary',
        text: 'Schedule consultation',
        href: '/contact',
      },
    ]}
  />
</Layout>
