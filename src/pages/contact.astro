---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Start the Conversation | Radynox-Draivra Execution Partnership',
  description:
    'Start a thoughtful conversation with Radynox-Draivra about your next step, your current bottleneck, or the systems you need to build.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Start with clarity"
    title="Connect with Radynox–Draivra"
    subtitle="This is a founder-to-founder conversation first. Share what you are building and we will see whether it is the right fit."
  />

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-8">
        <h2 class="text-3xl font-semibold text-gray-900 dark:text-white">Tell us where you are headed</h2>
        <p class="mt-4 text-lg leading-8 text-gray-600 dark:text-slate-300">
          Whether you are exploring an idea, looking for clearer next steps, or trying to work through an early-stage problem, I am here to listen.
        </p>

        <div data-fs-success class="mt-6 hidden rounded-lg bg-green-100 p-4 text-green-800">
          Thank you! We received your message and will respond within one business day.
        </div>
        <div data-fs-error class="mt-6 hidden rounded-lg bg-red-100 p-4 text-red-800"></div>

        <form action="https://formspree.io/f/xpqgpyvp" method="POST" class="mt-8">
          <div class="mb-6">
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-slate-300">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-md dark:border-slate-700 dark:bg-slate-950"
            />
          </div>

          <div class="mb-6">
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-slate-300">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-md dark:border-slate-700 dark:bg-slate-950"
            />
          </div>

          <div class="mb-6">
            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-slate-300">Tell us about your journey</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-md dark:border-slate-700 dark:bg-slate-950"
            ></textarea>
          </div>

          <div class="mt-3 flex items-start">
            <input id="disclaimer" name="disclaimer" type="checkbox" required class="mt-1 cursor-pointer" />
            <label for="disclaimer" class="ml-3 cursor-pointer select-none text-sm text-gray-600 dark:text-slate-400">
              By submitting this form, you agree to our collection of your information so we can respond to your request.
            </label>
          </div>

          <div class="mt-8">
            <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-3 font-semibold text-white transition hover:bg-blue-700">
              Start the conversation
            </button>
          </div>
        </form>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-8">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Direct contact</h3>
        <ul class="mt-6 space-y-4 text-gray-600 dark:text-slate-300">
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">Primary email</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="mailto:info@radynox.com">
              info@radynox.com
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">Direct</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="mailto:deepak@radynox.com">
              deepak@radynox.com
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">X</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="https://twitter.com/deepaksahani74" target="_blank">
              twitter.com/deepaksahani74
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">LinkedIn</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="https://www.linkedin.com/in/deepak-sahani-2911b9380/" target="_blank">
              linkedin.com/in/deepak-sahani-2911b9380/
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
