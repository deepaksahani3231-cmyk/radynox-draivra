---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Start with clarity" title="Connect with Radynox-Draivra" />

  <!-- Contact Form with Formspree ******* -->

  <div class="max-w-7xl mx-auto">
    <div
      class="flex flex-col max-w-xl mx-auto rounded-lg backdrop-blur border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow p-4 sm:p-6 lg:p-8 w-full"
    >
      <h2 class="text-3xl font-bold mb-2">Tell us where you're headed</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-6">
        Whether you are exploring an idea, looking for connections, or seeking a clearer next step, we're here to
        listen.
      </p>

      <div data-fs-success class="hidden bg-green-100 text-green-800 p-4 rounded mb-4">
        Thank you! We received your message and will respond within one business day.
      </div>
      <div data-fs-error class="hidden bg-red-100 text-red-800 p-4 rounded mb-4"></div>

      <form id="contact-form">
        <div class="mb-6">
          <label for="name" class="block text-sm font-medium">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
            data-fs-field
          />
          <span data-fs-error="name" class="text-red-500 text-sm mt-1 block"></span>
        </div>

        <div class="mb-6">
          <label for="email" class="block text-sm font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
            data-fs-field
          />
          <span data-fs-error="email" class="text-red-500 text-sm mt-1 block"></span>
        </div>

        <div class="mb-6">
          <label for="message" class="block text-sm font-medium">Tell us about your journey</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
            data-fs-field></textarea>
          <span data-fs-error="message" class="text-red-500 text-sm mt-1 block"></span>
        </div>

        <div class="mt-3 flex items-start">
          <input id="disclaimer" name="disclaimer" type="checkbox" required class="mt-1 cursor-pointer" />
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400 ml-3">
            By submitting this form, you agree to our collection of your information so we can respond to your request.
          </label>
        </div>

        <div class="mt-10">
          <button
            type="submit"
            data-fs-submit-btn
            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg"
          >
            Contact us
          </button>
        </div>

        <div class="mt-3 text-center">
          <p class="text-sm text-gray-600 dark:text-gray-400">
            We aim to respond within one business day with a practical next step or resource.
          </p>
        </div>
      </form>
    </div>
  </div>

  <!-- Features2 Widget ************** -->

  <Features2
    title="How we can help"
    items={[
      {
        title: 'Ecosystem navigation',
        description:
          'We help you understand the communities, programs, and practical support that are available to you now.',
      },
      {
        title: 'Opportunity discovery',
        description: 'We share pathways that fit your stage instead of pointing to one-size-fits-all solutions.',
      },
      {
        title: 'Connections and resources',
        description:
          'We connect people to relevant networks, people, and programs without promising they will solve every problem.',
      },
      {
        title: 'Email',
        description: 'info@radynox.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Phone',
        description: '+91 74165 32840',
        icon: 'tabler:phone',
      },
      {
        title: 'Location',
        description: 'Uttar Pradesh, India',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Response time',
        description: 'Within one business day for discovery requests.',
        icon: 'tabler:clock',
      },
    ]}
  />
  <!-- Formspree Script ************** -->
  <script is:inline>
    window.formspree =
      window.formspree ||
      function () {
        window.formspree =
          window.formspree ||
          function (...args) {
            (window.formspree.q = window.formspree.q || []).push(...args);
          };
      };
    window.formspree('initForm', { formElement: '#contact-form', formId: 'xpqgpyvp' });
  </script>
  <script is:inline src="https://unpkg.com/@formspree/ajax@1" defer></script></Layout
>
