---
import Layout from '~/layouts/LandingLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Founder Success Stories | Radynox-Draivra',
  description: 'Real journeys of founders building sustainable businesses with systems and clarity.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Founder Clarity Program"
    title="From Overwhelm to Execution: Build Systems That Work"
    subtitle="When everything depends on you, nothing scales. We help founders build the operational clarity and documented systems that create freedom. Your team executes. You focus on growth."
    actions={[
      { variant: 'primary', text: 'Explore Systems', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'See our approach', href: '/about' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321497487-e288fb19713f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Click-through Landing Page Hero Image',
    }}
  />

  <CallToAction
    title="Ready to stop being the bottleneck?"
    subtitle="Get direct access to founder execution coaching and systems building. Move your team forward without burning yourself out."
    actions={[
      {
        variant: 'primary',
        text: 'Schedule a Consultation',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>
