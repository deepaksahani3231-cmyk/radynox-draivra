---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Founder Toolkit & Resources | Radynox-Draivra',
  description: 'Essential tools, templates, and playbooks for every stage of your founder journey.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="Founder Toolkit & Resources"
    title="Tools designed for founders, by founders"
    subtitle="Every founder needs tools that work. Not flashy SaaS platforms, but practical frameworks, templates, and playbooks that help you build operational systems quickly. Everything you need to move from idea to sustainable business."
    actions={[
      { variant: 'primary', text: 'Explore Toolkit', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'Learn more', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2174&q=80',
      alt: 'Founder toolkit and resources',
    }}
  />

  <CallToAction
    title="Get the founder tools you need"
    subtitle="Stop searching for random templates. Get a complete toolkit designed specifically for founder execution and growth."
    actions={[
      {
        variant: 'primary',
        text: 'Access Toolkit',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>
