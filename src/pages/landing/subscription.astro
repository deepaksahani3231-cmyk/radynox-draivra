---
import Layout from '~/layouts/LandingLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Founder Membership Programs | Radynox-Draivra',
  description: 'Community, resources, and ongoing support for founders at every stage of growth.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Founder Membership Program"
    title="Join 500+ Founders Building with Systems and Clarity"
    subtitle="Monthly guidance, execution support, and community. We work directly with you to reduce execution pressure, build operational systems, and keep you accountable to real progress."
    actions={[
      { variant: 'primary', text: 'Join the Community', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'See pricing', href: '/pricing' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1593510987046-1f8fcfc512a0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Ironic image associated with canceling a subscription. Subscription Landing Page Demo',
    }}
  />

  <CallToAction
    title="Ready to level up as a founder?"
    subtitle="Join 500+ founders in a community committed to sustainable, systems-driven growth."
    actions={[
      {
        variant: 'primary',
        text: 'Explore Membership',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>
