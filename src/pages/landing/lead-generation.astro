---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Founder Outreach Program | Radynox-Draivra',
  description: 'Build relationships, find partners, and grow your founder network. Strategic outreach for sustainable growth.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="Founder Outreach Program"
    title="Build Your Founder Network: Strategic Relationships for Real Growth"
    subtitle="Most solo founders lack a network. We help you build genuine relationships with other founders, mentors, and partners who amplify your impact and accelerate your progress. Strategic founder networking isn't about spamming—it's about finding your people."
    actions={[
      { variant: 'primary', text: 'Start Building Connections', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'Learn our approach', href: '/about' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1674&q=80',
      alt: 'Founder networking and relationship building',
    }}
  />

  <CallToAction
    title="Ready to build your founder network?"
    subtitle="Strategic relationships compound. Let us help you reach the right people, at the right time, with the right message."
    actions={[
      {
        variant: 'primary',
        text: 'Start Networking',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>
