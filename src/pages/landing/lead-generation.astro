---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Founder Outreach Program | Radynox-Draivra',
  description: 'Build relationships, find partners, and grow your founder network. Strategic outreach for sustainable growth.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="Founder Outreach Program"
    title="Build relationships that drive sustainable growth"
    subtitle="Strategic founder networking isn't about spamming. It's about building genuine relationships with partners, mentors, and collaborators who amplify your impact. Learn how to reach out effectively and build a network that matters."
    actions={[
      { variant: 'primary', text: 'Join the Program', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'Learn more', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1674&q=80',
      alt: 'Founder networking and relationship building',
    }}
  />

  <CallToAction
    title="Ready to build your founder network?"
    subtitle="Strategic relationships compound. Let us help you reach the right people, at the right time, with the right message."
    actions={[
      {
        variant: 'primary',
        text: 'Start Networking',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>
