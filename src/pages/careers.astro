---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Careers at Radynox-Draivra | Join Our Team',
  description: 'Join Radynox-Draivra and help founders build practical systems, operational clarity, and lasting growth.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Careers at Radynox-Draivra"
    title="Help founders build execution systems and operational clarity"
    subtitle="Join a mission-driven team focused on helping founders scale beyond founder-dependent operations through systems, strategy, and sustainable growth."
    callToAction={{ text: 'View opportunities', href: '/contact' }}
  />

  <Features2
    title="What makes Radynox-Draivra special"
    subtitle="We hire people who are passionate about founder success, systems design, and operational excellence."
    columns={3}
    items={[
      {
        title: 'Founder-centric mission',
        description: 'Work with a team that deeply understands founder challenges and builds systems, not templates.',
        icon: 'tabler:target',
      },
      {
        title: 'Impact and delivery',
        description: 'Work directly with founders on systems design, execution coaching, financial clarity, and team operations.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Growth and learning',
        description: 'Develop expertise in founder execution, scaling systems, and operational strategy across diverse industries.',
        icon: 'tabler:bulb',
      },
    ]}
  />
</Layout>
