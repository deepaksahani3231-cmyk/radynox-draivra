---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services for Founders | Radynox-Draivra',
  description: 'Founder execution systems, operations coaching, financial clarity, and team building services.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Our Services"
    title="Operational Systems & Execution Support"
    subtitle="We build practical systems, streamline operations, and work alongside founders to reduce execution pressure—so you can focus on growing your business instead of managing every task yourself."
    actions={[{ variant: 'primary', target: '_self', text: 'Schedule a consultation', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Founder execution and team operations',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="What we provide"
    subtitle="Founder-focused services designed for execution, scale, and sustainable growth."
    columns={3}
    items={[
      {
        title: 'Execution systems design',
        description:
          'We design workflows for hiring, financial management, decision-making, and team communication tailored to your stage.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Founder operations coaching',
        description: 'One-on-one guidance to help you delegate, build accountability, and focus on strategy instead of execution.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Financial clarity workshops',
        description:
          'Understand your unit economics, runway, cash flow, and build financial discipline into your operations.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Team building and scaling',
        description: 'Navigate hiring, culture, and organizational structure as you grow from founder solo to scaled team.',
        icon: 'tabler:users',
      },
      {
        title: 'Process documentation',
        description: 'Create playbooks, decision frameworks, and knowledge systems that survive founder handoff.',
        icon: 'tabler:book',
      },
      {
        title: 'Strategy and growth planning',
        description: 'Quarterly planning, market strategy, and execution roadmaps that actually get executed.',
        icon: 'tabler:compass',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Systems that stick',
        description: 'We design operational systems that fit your company culture and actually get used by your team.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Founder-led implementation',
        description: 'You stay in control. We guide, coach, and support your team through adoption and adaptation.',
        icon: 'tabler:user',
      },
      {
        title: 'Financial rigor',
        description: 'Build a financial discipline culture from day one with clear metrics, dashboards, and accountability.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Scalable processes',
        description: 'Processes and documentation that make it possible to add team members without losing quality.',
        icon: 'tabler:trending-up',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=870&q=80',
      alt: 'Founder operations and systems',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Systems built for founder success
      </h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Focus on strategy',
        description: 'Clear systems free you from operational chaos and give you time to focus on vision and growth.',
        icon: 'tabler:target',
      },
      {
        title: 'Team alignment',
        description: 'Documented systems create clarity and accountability across your entire team.',
        icon: 'tabler:users',
      },
      {
        title: 'Scalable growth',
        description: 'Add team members confidently because systems, not founders, are the foundation of your operation.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Founder breathing room',
        description: 'Reduce founder burnout by building businesses that don\'t depend on your constant presence.',
        icon: 'tabler:heart',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Founder success outcomes',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Outcomes we drive
      </h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Founder outcomes"
    testimonials={[
      {
        testimonial: `Radynox-Draivra gave us the operational framework we needed to scale without founder burnout. Systems that actually work, implemented by people who understand startup reality.`,
        name: 'Alex Rivera',
        job: 'Founder, Growth-stage startup',
        image: {
          src: 'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=930&q=80',
          alt: 'Founder testimonial image',
        },
      },
      {
        testimonial: `Clear financial systems, documented processes, and a team that knows what to do. This is what sustainable growth looks like. Highly recommend for any serious founder.`,
        name: 'Jordan Lee',
        job: 'CEO, Tech-enabled services',
        image: {
          src: 'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Founder testimonial image',
        },
      },
    ]}
    callToAction={{
      target: '_self',
      text: 'Schedule a consultation',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Schedule a consultation',
        href: '/contact',
      },
    ]}
    title="Ready to transform your operations?"
    subtitle="Let's discuss how we can help you build systems that scale."
  />
</Layout>
