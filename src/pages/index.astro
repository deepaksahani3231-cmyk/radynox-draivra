---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';

const metadata = {
  title: 'Radynox–Draivra — Execution partnership for early-stage founders',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start the Conversation',
        href: '#contact',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Connect on LinkedIn',
        href: 'https://www.linkedin.com/in/deepaksahani-2911b9380',
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Solo founder building with clarity' }}
  >
    <Fragment slot="title">The Missing First Hire for Solo Founders</Fragment>

    <Fragment slot="subtitle">
      <span class="block text-lg font-medium leading-relaxed text-gray-700 dark:text-slate-300">
        Execution partnership for early-stage builders — from idea to first customer, without the noise of generic advice or the cost of a co-founder.
      </span>
    </Fragment>
  </Hero>

  <section id="who-this-is-for" class="scroll-mt-24 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">Who This Is For</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          For founders who need structure before they need capital.
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600 dark:text-slate-300">
          This is built for the earliest stage — when the idea is real, the pressure is high, and most support systems have gone quiet.
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Ideal fit</h3>
          <ul class="mt-6 space-y-3 text-gray-600 dark:text-slate-300">
            <li>• First-time founders with no co-founder, no network, and no funding</li>
            <li>• Builders rebuilding after a failed startup</li>
            <li>• Idea-stage founders who need structure before they need capital</li>
            <li>• Anyone tired of generic startup advice that does not translate to action</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Who This Is Not For</h3>
          <ul class="mt-6 space-y-3 text-gray-600 dark:text-slate-300">
            <li>• Funded startups looking for scaling advisors</li>
            <li>• Founders seeking financial or legal consulting</li>
            <li>• Teams that already have execution systems in place</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="about-founder" class="scroll-mt-24 border-t border-gray-200/80 py-20 sm:py-24 dark:border-slate-800">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">About the Founder</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Most founders do not fail because of bad ideas. They fail because they carry everything alone for too long.
        </h2>
        <div class="mt-6 space-y-4 text-lg leading-8 text-gray-600 dark:text-slate-300">
          <p>
            I am Deepak Sahani, founder of Radynox–Draivra. I came from a construction background in a small town in Uttar Pradesh — no network, no money, no team, no shortcuts.
          </p>
          <p>
            I built this practice from that exact experience because I know what it costs to build completely alone. I work with founders before traction, before visibility, and before anyone is paying attention.
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Connect</h3>
        <ul class="mt-6 space-y-4 text-gray-600 dark:text-slate-300">
          <li>
            <a class="font-medium text-blue-600 transition hover:text-blue-700" href="https://www.linkedin.com/in/deepaksahani-2911b9380" target="_blank">
              linkedin.com/in/deepaksahani-2911b9380
            </a>
          </li>
          <li>
            <a class="font-medium text-blue-600 transition hover:text-blue-700" href="mailto:info@radynox.com">
              info@radynox.com
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="scroll-mt-24 border-t border-gray-200/80 py-20 sm:py-24 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">How It Works</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          A direct working partnership for the earliest, hardest stage.
        </h2>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Founder Foundation Building</h3>
          <p class="mt-3 text-gray-600 dark:text-slate-300">
            Breaking your idea down to its core and rebuilding clarity around the problem, the offer, and the next step.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Execution Support</h3>
          <p class="mt-3 text-gray-600 dark:text-slate-300">
            Product planning, UI/UX direction, branding, website setup, workflows, and go-to-market strategy.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Operational Structure</h3>
          <p class="mt-3 text-gray-600 dark:text-slate-300">
            Designing your first roles, systems, pipelines, and distribution strategy so the work becomes manageable.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Weekly Clarity Sessions</h3>
          <p class="mt-3 text-gray-600 dark:text-slate-300">
            So you are never stuck without a next step. This is built for the earliest stage, not scaling.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Note
    title="Early Beta — Currently working with my first founders"
    description="This is an early, hands-on engagement model built for the earliest, hardest stage. I am not presenting early numbers as established traction."
  />

  <section id="working-with-founders" class="scroll-mt-24 border-t border-gray-200/80 py-20 sm:py-24 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">Working With Founders</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Confidentiality is part of the service.
        </h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-slate-300">
          I am currently working closely with early-stage founders across different industries — from beverage brands to first-time product launches. Every founder’s idea is confidential until they are ready to go public.
        </p>
      </div>

      <div class="mt-10 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <p class="text-gray-600 dark:text-slate-300">
          I respect that trust completely, which means you will not see names, products, or details here until my founders choose to share their story. I am also supporting founders in company formation, funding strategy, and go-to-market planning — real work, kept private by design.
        </p>
      </div>
    </div>
  </section>

  <section id="engagement" class="scroll-mt-24 border-t border-gray-200/80 py-20 sm:py-24 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">Engagement</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          This is a founder-to-founder conversation first, not a sales pitch.
        </h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-slate-300">
          DM or email to share what you are building. If it is a fit, we will agree on how we work together — pricing and structure depend on your stage and needs, and will be discussed directly and transparently before anything begins.
        </p>
      </div>
    </div>
  </section>

  <section id="contact" class="scroll-mt-24 border-t border-gray-200/80 py-20 sm:py-24 dark:border-slate-800">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-[1fr_0.85fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600">Contact</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Start the conversation.
        </h2>
        <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-slate-300">
          If you are building early, carrying too much alone, or need a clearer path forward, reach out. I will respond with a practical next step.
        </p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <ul class="space-y-4 text-gray-600 dark:text-slate-300">
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">Email</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="mailto:info@radynox.com">
              info@radynox.com
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">Direct</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="mailto:deepak@radynox.com">
              deepak@radynox.com
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">X</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="https://twitter.com/deepaksahani74" target="_blank">
              twitter.com/deepaksahani74
            </a>
          </li>
          <li>
            <span class="block text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">LinkedIn</span>
            <a class="mt-1 inline-block font-medium text-blue-600 transition hover:text-blue-700" href="https://www.linkedin.com/in/deepaksahani-2911b9380" target="_blank">
              linkedin.com/in/deepaksahani-2911b9380
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
