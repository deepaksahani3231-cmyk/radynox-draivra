---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Radynox–Draivra™ — Practical execution support for solo founders',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Get started',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'DM Deepak', href: 'https://x.com/deepaksahani3231' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Solo founder building' }}
  >
    <Fragment slot="title"> You're building alone. You don't have to carry this weight by yourself. </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        I came from construction work with no network, no money, no team. I built Radynox–Draivra because I know what it costs to build completely alone. So I help first-time founders get practical execution support, clarity from day zero, and real guidance so you never feel abandoned.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">You're building alone. That changes today.</span>
      Execution support, not just advice. Weekly guidance. Real clarity. For founders at the stage nobody else wants to help.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note
    title="The problem:"
    description="Most founders fail not because their idea is bad. They fail because they're building alone—no one to talk to, no systems to follow, no guidance when everything feels impossible. By pre-traction, the help dries up entirely."
  />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Who we serve"
    title="First-time founders. Solo builders. People building with nothing."
    subtitle="If this is you, Radynox–Draivra is for you."
    items={[
      {
        title: 'First-time founders with no network',
        description:
          'You have an idea. No connections. No money. No team yet. You need someone who understands what that feels like.',
        icon: 'tabler:user-circle',
      },
      {
        title: 'Founders who failed and want to rebuild',
        description:
          'You have been through it. You learned something. Now you want to try again with better systems, better clarity, better support.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Students and curious builders with ideas',
        description:
          'You have energy and ideas but no guidance. Nobody taught you how to turn that into something real. We help.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Pre-revenue, pre-traction builders',
        description:
          'You are building but have not found product-market fit yet. Most advisors have moved on. We have not.',
        icon: 'tabler:rocket',
      },
      {
        title: 'People building completely alone',
        description:
          'No co-founder. No team. No one to bounce ideas off of at 11 PM when everything feels impossible. You need real support.',
        icon: 'tabler:user',
      },
      {
        title: 'Anyone rebuilding a stalled or failed idea',
        description:
          'You had something that did not work. But the idea has life. You want to build it right this time, with real systems.',
        icon: 'tabler:tool',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="What we do"
    title="Practical execution support, not just mentorship advice."
    items={[
      {
        title: 'Product planning and strategy',
        description:
          'Help you figure out what to build first, who it is for, and why it matters. Real clarity from day zero.',
      },
      {
        title: 'Branding and positioning',
        description:
          'Help you tell your story. What makes you different. How to stand out without pretending to be something you are not.',
      },
      {
        title: 'Go-to-market and workflows',
        description:
          'Help you get your first customers. Build systems that work for one person. Workflows you can actually execute alone.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Practical execution support',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Weekly guidance. Real support.</h3>
      You get access to someone who has actually built something from nothing. Someone who understands execution pressure because he lived it.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'We are NOT a scaling advisor',
        description:
          'We do not help you scale a business. We help you build it from zero. Once you have traction, you graduate to advisors who know that world.',
      },
      {
        title: 'We are NOT a financial consultant',
        description:
          'We do not talk about unit economics or runway or fundraising. We talk about building systems one person can actually execute.',
      },
      {
        title: 'We are NOT for funded or established startups',
        description:
          'If you have money, team, or traction, our work is done. You need someone else. We are for the people nobody else wants to help yet.',
      },
      {
        title: 'We do not do generic startup advice',
        description: 'We work directly with you. We understand your specific challenge. We give you actual systems, not frameworks.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'What we are not',
    }}
  >
    <Fragment slot="content">We make next steps easier to see, even when the path feels unclear.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'You get practical support',
        description:
          'Not a dashboard, not a forum. Direct access to someone who understands execution pressure because they have lived it.',
      },
      {
        title: 'You get real clarity',
        description: 'What to build. Who it is for. How to talk about it. How to get first customers. Concrete next steps.',
      },
      {
        title: 'You get weekly guidance',
        description:
          'Calls, messages, whatever you need. You are never the only person thinking about your business anymore.',
      },
      {
        title: 'You get systems, not frameworks',
        description:
          'We do not give you generic advice. We help you build the actual operating systems your solo-founder life requires.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611462985358-60d3498e0364?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'What you actually get',
    }}
  >
    <Fragment slot="content">What you actually get with Radynox–Draivra</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="how"
    title="How Radynox–Draivra works"
    items={[
      {
        title: 'Step 1: <span class="font-medium">You tell us your idea and challenge</span>',
        description: 'What are you building? Where are you stuck? What keeps you up at night? We listen to understand your specific situation.',
        icon: 'tabler:message',
      },
      {
        title: 'Step 2: <span class="font-medium">We build your execution systems</span>',
        description: 'Together we map out: your product, your positioning, your GTM strategy, and the workflows you can actually execute alone.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Step 3: <span class="font-medium">Weekly check-ins and guidance</span>',
        description:
          'You are never building alone. We talk every week. We troubleshoot. We refine. We keep you moving forward.',
        icon: 'tabler:phone',
      },
      {
        title: 'You get real traction',
        description:
          'A clear product. Real customers. Momentum. Systems that work. And the confidence that you know what you are doing.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'How Radynox-Draivra works',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Why Radynox–Draivra is different"
    subtitle="We are not building another tool. We are here to help you actually build your idea."
    tagline="The difference"
    items={[
      {
        title: 'Founder-founded',
        description:
          'I built this because I lived it. No network. No money. No team. I know the weight you are carrying.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Execution-focused',
        description: 'We do not give you frameworks. We help you build actual systems. Things that work for one person.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Weekly partnership',
        description: 'This is not passive. You get regular guidance. We are in this together.',
        icon: 'tabler:friends',
      },
      {
        title: 'Pre-traction specialization',
        description: 'Most advisors graduate to scaling advice once you have momentum. We specialize in the hard part: zero to traction.',
        icon: 'tabler:star',
      },
      {
        title: 'Honest about limitations',
        description:
          'We are not a financial advisor. Not a scaling consultant. Not for funded startups. We are for solo founders building from scratch.',
        icon: 'tabler:circle-check',
      },
      {
        title: 'You are not alone anymore',
        description:
          'The weight you have been carrying? You stop carrying it alone. That changes everything.',
        icon: 'tabler:heart',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Founder notes on building alone"
    information={`Practical guidance for solo founders. No hype. Just real strategies that work when you're the only person carrying the weight.`}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Your questions about Radynox–Draivra"
    subtitle="Honest answers for solo founders."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is Radynox–Draivra?',
        description:
          'Practical execution support for solo founders building from zero. Not mentorship. Not scaling advice. Real guidance on product, positioning, GTM, and the systems you need to execute alone.',
      },
      {
        title: 'Who is this for?',
        description:
          'First-time founders with no network or money. Founders rebuilding after a failed attempt. Students with ideas. Anyone building completely alone before traction.',
      },
      {
        title: 'What will you help me with?',
        description: 'Product strategy, branding and positioning, go-to-market planning, building workflows you can execute solo, and weekly guidance on whatever is blocking you.',
      },
      {
        title: 'How does this actually work?',
        description:
          'You tell us your idea and challenge. We build systems together. We meet weekly. We help you get to real traction with a clear product, positioning, and first customers.',
      },
      {
        title: 'What are you NOT?',
        description:
          'We are not a financial consultant. Not a scaling advisor. Not for funded startups. Not about hiring, unit economics, or runway. We are only for solo founders at pre-traction stage.',
      },
      {
        title: 'How do I get started?',
        description: 'Visit radynox.in or DM Deepak on X. We will talk through your idea and see if we are the right fit.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Solo founders supported', amount: '500+' },
      { title: 'Systems built', amount: '200+' },
      { title: 'Pre-traction founders we have helped', amount: '200+' },
      { title: 'Weekly guidance sessions', amount: '1K+' },
    ]}
  />

  <!-- Contact anchor for hero CTA -->
  <section id="contact" class="scroll-mt-24">
    <CallToAction
      actions={[
        {
          variant: 'primary',
          text: 'Get started',
          href: '/contact',
          icon: 'tabler:arrow-right',
        },
      ]}
    >
      <Fragment slot="title"> You are building alone. You do not have to. </Fragment>

      <Fragment slot="subtitle">
        Execution support, clarity, and weekly guidance for the founder carrying the weight alone. Visit radynox.in or DM Deepak to start.
      </Fragment>
    </CallToAction>
  </section>
</Layout>
