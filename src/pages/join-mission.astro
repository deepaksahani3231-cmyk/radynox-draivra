---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Join our mission | Radynox-Draivra',
  description: 'Join a mission-driven effort to help founders build durable operations, stronger systems, and more sustainable growth.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Join our mission"
    title="Help founders move from chaos to operational clarity"
    subtitle="Partner with us to provide execution systems, operational coaching, and strategic guidance that helps founders scale without founder burnout."
    actions={[
      { variant: 'primary', text: 'Get involved', href: '/contact' },
      { text: 'Learn about our approach', href: '/about' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Founder execution systems and operations',
    }}
  />

  <Features2
    title="Our mission foundation"
    subtitle="What we believe about founder execution and sustainable growth."
    tagline="How to help"
    columns={3}
    items={[
      {
        title: 'Systems over heroics',
        description: 'Help founders escape founder-dependent chaos by building sustainable systems and scalable processes.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Execution focus',
        description:
          'Emphasize practical implementation, operational clarity, and measurable outcomes over theory and consulting speak.',
        icon: 'tabler:target',
      },
      {
        title: 'Founder partnership',
        description:
          'Support founders as genuine partners committed to sustainable growth, not consultants pushing one-size-fits-all solutions.',
        icon: 'tabler:users',
      },
      {
        title: 'Operational transparency',
        description: 'Build clear accountability, documented processes, and team alignment that survives founder transitions.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Sustainable scaling',
        description: 'Help founders scale from startup chaos to organized operations without sacrificing founder wellbeing.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Founder breathing room',
        description:
          'Champion the idea that founders deserve operational systems that free them to focus on strategy and growth.',
        icon: 'tabler:heart',
      },
    ]}
  />

  <CallToAction
    title="Ready to join the founder execution movement?"
    subtitle="Let's work together to help founders build sustainable, scalable operations."
    actions={[
      {
        variant: 'primary',
        text: 'Get involved',
        href: '/contact',
      },
    ]}
  />
</Layout>
